# Public app name shown in metadata. Optional — falls back to "Science Prompt Composer".
NEXT_PUBLIC_APP_NAME="Science Prompt Composer"

# Generation backend. "local" uses the built-in rule/template engine and needs no API key.
# Reserved values for future integrations: "openai", "anthropic".
GENERATION_MODE="local"

# Only needed if a future LLM-backed GenerationService is enabled. Leave empty for local mode.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
